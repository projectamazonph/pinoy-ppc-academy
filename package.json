{
  "name": "pinoy-ppc-academy",
  "version": "0.2.0",
  "private": true,
  "description": "Pinoy PPC Academy - career-first Amazon PPC training for Filipino virtual assistants.",
  "license": "MIT",
  "engines": { "node": ">=20.9.0", "npm": ">=10.0.0" },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "guard:no-ai": "node scripts/check-no-ai.mjs",
    "guard:content": "node scripts/check-content-trust.mjs",
    "verify": "npm run guard:no-ai && npm run guard:content && npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.37.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
